# Application Makefile — builds the GPSU21 print-server application against
# the eCos kernel library (libtarget.a) generated by the top-level Makefile.
#
# Variables supplied by the parent Makefile:
#   CROSS_COMPILE   — toolchain prefix (e.g. mipsel-elf-)
#   ECOS_INSTALL    — path to ecos_build/install
#   WEB_DIR         — path to gpsu21_web/ (HTML/JS/CSS/images)
#   OUTPUT          — destination ELF path

# ──────────────────────────────────────────────────────────────────────────────
# Toolchain
# ──────────────────────────────────────────────────────────────────────────────
CC      := $(CROSS_COMPILE)gcc
LD      := $(CROSS_COMPILE)gcc
OBJCOPY := $(CROSS_COMPILE)objcopy

# ──────────────────────────────────────────────────────────────────────────────
# Paths
# ──────────────────────────────────────────────────────────────────────────────
BUILD_DIR  := $(dir $(OUTPUT))
SRC_DIR    := $(CURDIR)
ECOS_INC   := $(ECOS_INSTALL)/include
ECOS_LIB   := $(ECOS_INSTALL)/lib

# ──────────────────────────────────────────────────────────────────────────────
# MIPS load address — must match the value the ZOT bootloader expects.
# The decompressed eCos image is always placed at 0x80000400.
# ──────────────────────────────────────────────────────────────────────────────
LOAD_ADDR := 0x80000400

# ──────────────────────────────────────────────────────────────────────────────
# Compiler flags
# ──────────────────────────────────────────────────────────────────────────────
CFLAGS := \
    -mips32r2 \
    -EL \
    -march=mips32r2 \
    -msoft-float \
    -fno-builtin \
    -ffunction-sections \
    -fdata-sections \
    -Os \
    -g \
    -Wall \
    -Wextra \
    -I$(ECOS_INC) \
    -I$(SRC_DIR) \
    -DCYG_HAL_STARTUP_ROM \
    -DRAM_STARTUP

LDFLAGS := \
    -EL \
    -mips32r2 \
    -nostartfiles \
    -Wl,--gc-sections \
    -Wl,-Map=$(BUILD_DIR)/gpsu21_app.map \
    -Wl,-Ttext=$(LOAD_ADDR) \
    -L$(ECOS_LIB) \
    $(ECOS_LIB)/libtarget.a \
    $(ECOS_LIB)/libextras.a

# ──────────────────────────────────────────────────────────────────────────────
# Sources
# ──────────────────────────────────────────────────────────────────────────────
SRCS := \
    main.c \
    httpd.c \
    ipp_server.c \
    mdns.c \
    lpr.c

# The web-resource table is generated from the gpsu21_web/ directory.
# Each file is embedded as a C byte array; the table mirrors the ROM file
# table layout expected by the HTTP server (see tools/unpack_gpsu21.py).
GENERATED_SRCS := $(BUILD_DIR)/web_resources.c

OBJS := $(addprefix $(BUILD_DIR)/, $(SRCS:.c=.o)) \
        $(BUILD_DIR)/web_resources.o

# ──────────────────────────────────────────────────────────────────────────────
# Rules
# ──────────────────────────────────────────────────────────────────────────────
.PHONY: all clean

all: $(OUTPUT)

$(OUTPUT): $(OBJS)
	$(LD) $(OBJS) $(LDFLAGS) -o $@
	@echo "  Linked: $@"

$(BUILD_DIR)/%.o: $(SRC_DIR)/%.c | $(BUILD_DIR)
	$(CC) $(CFLAGS) -c $< -o $@

$(BUILD_DIR)/web_resources.o: $(GENERATED_SRCS) | $(BUILD_DIR)
	$(CC) $(CFLAGS) -c $< -o $@

# Generate web_resources.c from the gpsu21_web/ directory
$(GENERATED_SRCS): $(wildcard $(WEB_DIR)/*) | $(BUILD_DIR)
	python3 $(SRC_DIR)/gen_web_resources.py $(WEB_DIR) $@
	@echo "  Generated: $@"

$(BUILD_DIR):
	mkdir -p $@

clean:
	rm -f $(OBJS) $(OUTPUT) $(GENERATED_SRCS) $(BUILD_DIR)/gpsu21_app.map
