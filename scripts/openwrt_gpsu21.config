# OpenWrt config fragment for the IOGear GPSU21 (MT7688 / ramips mt76x8)
#
# This fragment is intended for use with OpenWrt's build system config overlay
# mechanism.  Save it alongside your OpenWrt .config (or merge it in) before
# running `make`.
#
# IMPORTANT — kernel load address
# ────────────────────────────────
# The GPSU21's ZOT Technology bootloader always decompresses the firmware
# payload to physical DRAM address 0x00500000 (virtual KSEG0 0x80500000) and
# jumps there.  The kernel MUST be compiled for this load address or it will
# crash at boot.  The two settings below achieve this:
#
#   CONFIG_KERNEL_MIPS_LOADADDR_PHYSICAL  — OpenWrt Makefile variable used as
#       the load/entry address argument to mkimage (produces the uImage header
#       that package_openwrt_gpsu21.py expects).
#   CONFIG_PHYSICAL_START                 — Linux kernel Kconfig option that
#       sets the physical start address of the kernel image.
#
# The values below correspond to load address 0x80500000 (KSEG0, cached):
#   physical 0x00500000 = KSEG0 virtual 0x80500000

# ── Target ──────────────────────────────────────────────────────────────────
CONFIG_TARGET_ramips=y
CONFIG_TARGET_ramips_mt76x8=y
# Use a generic mt76x8 profile; replace with a GPSU21-specific profile once a
# board DTS has been submitted to OpenWrt upstream.
CONFIG_TARGET_ramips_mt76x8_DEVICE_generic=y

# ── Kernel load address ──────────────────────────────────────────────────────
# NOTE: KERNEL_LOADADDR is an OpenWrt *Makefile* variable (not a kernel Kconfig
# symbol) that controls the -a/-e arguments passed to mkimage.  It is set to
# 0x80500000 in the device profile added by build_openwrt_gpsu21.sh.
#
# The matching Linux kernel Kconfig option (a real CONFIG_ symbol) is set by
# the build script via the target's config-* file:
#   CONFIG_PHYSICAL_START=0x00500000   (kernel Kconfig — physical start address)
# Physical 0x00500000 = KSEG0 virtual 0x80500000 on MIPS.

# ── Kernel options ───────────────────────────────────────────────────────────
# Disable unused kernel features to keep image size down (target: ≤ 6 MB
# compressed, the typical GPSU21 firmware partition).
CONFIG_KERNEL_PRINTK=y
# CONFIG_KERNEL_PROFILING is not set
# CONFIG_KERNEL_KGDB is not set

# ── USB printer support ──────────────────────────────────────────────────────
# USB Printer Class kernel module — required for any attached USB printer.
CONFIG_PACKAGE_kmod-usb-printer=y
# USB storage (optional, for USB flash drives on the same hub)
# CONFIG_PACKAGE_kmod-usb-storage is not set

# ── Print server packages ────────────────────────────────────────────────────
# p910nd: lightweight pass-through print server (LPR port 9100/515).
# Minimal footprint (~20 KB); suitable when full CUPS is too large.
CONFIG_PACKAGE_p910nd=y

# cups: full-featured print server with IPP, LPR, and AirPrint support.
# Requires more flash (~3 MB); comment out p910nd above if using CUPS.
# CONFIG_PACKAGE_cups is not set

# avahi-daemon: mDNS/Bonjour daemon for AirPrint auto-discovery.
# Required for iOS/macOS AirPrint when using CUPS.
# CONFIG_PACKAGE_avahi-daemon is not set

# ── Networking extras ────────────────────────────────────────────────────────
CONFIG_PACKAGE_kmod-mt76=y          # MT7688 Wi-Fi driver (optional)
CONFIG_PACKAGE_iwinfo=y

# ── LuCI web interface (optional) ───────────────────────────────────────────
# Enable LuCI for router-style web configuration.  Adds ~1 MB; disable for a
# smaller image if you only need the print-server function.
# CONFIG_PACKAGE_luci is not set

# ── Build type: initramfs ────────────────────────────────────────────────────
# Build an initramfs-only kernel (kernel + rootfs in one LZMA blob).
# This is the simplest approach for initial testing — no separate rootfs flash
# partition is needed; the entire OS runs from RAM.
CONFIG_TARGET_ROOTFS_INITRAMFS=y
# CONFIG_TARGET_ROOTFS_SQUASHFS is not set
# CONFIG_TARGET_ROOTFS_EXT4FS is not set
